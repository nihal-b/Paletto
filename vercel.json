{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/index.js"
    }
  ],
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "functions": {
    "server/index.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
